<?xml version="1.0" encoding="utf-8"?>
<!--
    Enforces HTTPS for all network traffic in production.
    Blocks accidental HTTP requests that could leak data.
    Supabase, Google OAuth, and all external APIs already use HTTPS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust the system CA store (covers Supabase, Google, Stripe etc.) -->
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext to localhost for local Supabase dev server only -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.0.3.2</domain>
    </domain-config>
</network-security-config>
